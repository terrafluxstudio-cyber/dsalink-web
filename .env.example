# Optional: canonical site URL for metadataBase, sitemap, and JSON-LD (no trailing slash).
# Default: https://dsalink.sg
# NEXT_PUBLIC_SITE_URL=https://dsalink.sg

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Omit to disable gtag.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: override the primary MOE CTA URL (hero + DSA link cards).
# Default: https://www.moe.gov.sg/secondary/dsa
# NEXT_PUBLIC_MOE_PRIMARY_CTA_URL=https://www.moe.gov.sg/secondary/dsa

# Admin dashboard (/admin?key=...) — set a strong secret; also add in Vercel env.
# ADMIN_KEY=your_secret_password_here
