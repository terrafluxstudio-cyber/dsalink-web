{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.dsalink.sg" }],
      "destination": "https://dsalink.sg/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/drip",
      "schedule": "0 1 * * *"
    }
  ]
}
